      "roundness": null,
      "seed": 2716,
      "version": 1,
      "versionNonce": 2716,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "WHY: Raw rows never leave the server — API routes do the math. Cache and pagination are additive layers, not a rewrite of existing architecture.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WHY: Raw rows never leave the server — API routes do the math. Cache and pagination are additive layers, not a rewrite of existing architecture.",
      "autoResize": true,
      "lineHeight": 1.25
    },

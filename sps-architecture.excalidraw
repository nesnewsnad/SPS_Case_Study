    {
      "id": "s1-server-content",
      "type": "text",
      "x": 60,
      "y": 975,
      "width": 660,
      "height": 220,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 2012,
      "version": 1,
      "versionNonce": 2012,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "SQL aggregation (30+ queries across 6 routes)\n  - 596K rows aggregated server-side → ~2KB JSON responses\n  - Never ship raw claims to the browser\n\nAI reasoning + tool execution\n  - Claude Sonnet 4.6 decides: answer from EDA context OR call DB tools\n  - Tool queries run server-side, results fed back to model\n\nAI Process page (/process)\n  - Fully static server component — zero client JS shipped\n  - Renders instantly, no hydration cost\n\nSecurity: raw GROUP_IDs and NDCs never leave the server",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SQL aggregation (30+ queries across 6 routes)\n  - 596K rows aggregated server-side → ~2KB JSON responses\n  - Never ship raw claims to the browser\n\nAI reasoning + tool execution\n  - Claude Sonnet 4.6 decides: answer from EDA context OR call DB tools\n  - Tool queries run server-side, results fed back to model\n\nAI Process page (/process)\n  - Fully static server component — zero client JS shipped\n  - Renders instantly, no hydration cost\n\nSecurity: raw GROUP_IDs and NDCs never leave the server",
      "autoResize": true,
      "lineHeight": 1.25
    },

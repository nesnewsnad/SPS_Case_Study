      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The RAG \"next step\" in the SPS dashboard isn't speculative — it's integration of a pipeline that already exists and passes 621 tests.",
      "fontSize": 14,

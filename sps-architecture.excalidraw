      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Why this works:\n\nAI writes code faster than humans.\nAI reviews code WORSE than humans.\n\nSplit the roles: one agent plans\nand reviews, another implements.\nNeither does both.\n\nGit is the handoff protocol —\nspecs go in, verified code comes out.",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "s2-key-insight",
      "originalText": "Why this works:\n\nAI writes code faster than humans.\nAI reviews code WORSE than humans.\n\nSplit the roles: one agent plans\nand reviews, another implements.\nNeither does both.\n\nGit is the handoff protocol —\nspecs go in, verified code comes out.",
      "autoResize": true,
      "lineHeight": 1.25
    },

      "versionNonce": 2826,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "LLM TIERS\n\nHaiku 4.5 — query rewriting, HyDE, Self-RAG reflection\nSonnet 4.5 — primary RAG answers + analysis\nOpus 4.6 — IC memo synthesis, complex multi-document\n\n11 MCP tools exposed via FastMCP (stdio transport)\nAsync Python throughout · graceful stage degradation",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "s7-rag-llm",
      "originalText": "LLM TIERS\n\nHaiku 4.5 — query rewriting, HyDE, Self-RAG reflection\nSonnet 4.5 — primary RAG answers + analysis\nOpus 4.6 — IC memo synthesis, complex multi-document\n\n11 MCP tools exposed via FastMCP (stdio transport)\nAsync Python throughout · graceful stage degradation",
      "autoResize": true,
      "lineHeight": 1.25
    },

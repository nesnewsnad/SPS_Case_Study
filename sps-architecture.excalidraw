    {
      "id": "s7-rag-arch-text",
      "type": "text",
      "x": 80,
      "y": 4040,
      "width": 460,
      "height": 150,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",

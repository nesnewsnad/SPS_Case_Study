      "versionNonce": 2824,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "ARCHITECTURE\n\nSQLite-vec vector store — self-contained, no Pinecone\nFTS5 full-text index for keyword matching\nOpenAI text-embedding-3-large (3,072 dimensions)\n2-tier embedding cache (LRU memory + SQLite disk)\nSchema-Guided Response: entity/metric/period extraction\n512-token chunks with 2-sentence overlap",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "s7-rag-arch",
      "originalText": "ARCHITECTURE\n\nSQLite-vec vector store — self-contained, no Pinecone\nFTS5 full-text index for keyword matching\nOpenAI text-embedding-3-large (3,072 dimensions)\n2-tier embedding cache (LRU memory + SQLite disk)\nSchema-Guided Response: entity/metric/period extraction\n512-token chunks with 2-sentence overlap",
      "autoResize": true,
      "lineHeight": 1.25
    },

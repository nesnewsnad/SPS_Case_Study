      "text": "Auth + Row-Level Security\n\nJWT sessions per client organization\nPostgres RLS policies enforce entity_id scope",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "s7-r1-next",
      "originalText": "Auth + Row-Level Security\n\nJWT sessions per client organization\nPostgres RLS policies enforce entity_id scope",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "s7-r1-why",
      "type": "text",
      "x": 40,
      "y": 2983,
      "width": 1520,
      "height": 18,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 2710,
      "version": 1,
      "versionNonce": 2710,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "WHY: Adding a new pharmacy is a config change, not a code change — entity_id is already on every row and query. Auth + RLS locks each client to their own data.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WHY: Adding a new pharmacy is a config change, not a code change — entity_id is already on every row and query. Auth + RLS locks each client to their own data.",
      "autoResize": true,
      "lineHeight": 1.25
    },

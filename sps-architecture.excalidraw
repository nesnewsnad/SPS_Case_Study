    {
      "id": "s5-flow",
      "type": "text",
      "x": 40,
      "y": 2235,
      "width": 1500,
      "height": 180,
      "angle": 0,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 2410,
      "version": 1,
      "versionNonce": 2410,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "User clicks filter (e.g. state=CA, formulary=OPEN)\n    |\n    v\nFilterContext updates URL: ?state=CA&formulary=OPEN  (200ms debounce, accumulates rapid changes)\n    |\n    v\nPages re-render → API calls include ?state=CA&formulary=OPEN → cache key changes\n    |\n    v\nBackend: WHERE entity_id=1 AND pharmacy_state='CA' AND formulary='OPEN'  (dynamic JOIN only if MONY/drug/manufacturer filter active)\n    |\n    v\nCharts re-render with filtered data. Chat sidebar picks up filters too → system prompt Layer 5 updated.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User clicks filter (e.g. state=CA, formulary=OPEN)\n    |\n    v\nFilterContext updates URL: ?state=CA&formulary=OPEN  (200ms debounce, accumulates rapid changes)\n    |\n    v\nPages re-render → API calls include ?state=CA&formulary=OPEN → cache key changes\n    |\n    v\nBackend: WHERE entity_id=1 AND pharmacy_state='CA' AND formulary='OPEN'  (dynamic JOIN only if MONY/drug/manufacturer filter active)\n    |\n    v\nCharts re-render with filtered data. Chat sidebar picks up filters too → system prompt Layer 5 updated.",
      "autoResize": true,
      "lineHeight": 1.25
    },

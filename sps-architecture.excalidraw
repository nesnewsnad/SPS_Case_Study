      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Redis Cache + Cursor Pagination\n\nCache hot queries (KPIs, monthly trends)\nCursor pagination for million-row datasets",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "s7-r2-next",
      "originalText": "Redis Cache + Cursor Pagination\n\nCache hot queries (KPIs, monthly trends)\nCursor pagination for million-row datasets",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "s7-r2-why",
      "type": "text",
      "x": 40,
      "y": 3133,
      "width": 1520,
      "height": 18,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,

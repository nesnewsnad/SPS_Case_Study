    },
    {
      "id": "s8-subtitle",
      "type": "text",
      "x": 40,
      "y": 4412,
      "width": 1200,
      "height": 20,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 2902,
      "version": 1,
      "versionNonce": 2902,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The gap between case study and production is measured in days, not months — because the architecture was built expecting it.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",

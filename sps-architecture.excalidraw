      "versionNonce": 2722,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "WHY: Tests exist and pass today. Wiring into CI is configuration — no broken build ships, every PR gets a live preview URL automatically.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WHY: Tests exist and pass today. Wiring into CI is configuration — no broken build ships, every PR gets a live preview URL automatically.",
      "autoResize": true,
      "lineHeight": 1.25
    },
